# Backend Environment Variables

# MongoDB Connection String
# Format: mongodb://localhost:27017/database_name (local)
# or: mongodb+srv://username:password@cluster.mongodb.net/database_name (Atlas)
MONGO_URI=mongodb://localhost:27017/attendance_system

# JWT Secret Key - Use a long, random string
# Generate: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (Gmail example with App Password)
# To get Gmail App Password: https://support.google.com/accounts/answer/185833
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here

# Server Port
PORT=5000

# Node Environment (development/production)
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
